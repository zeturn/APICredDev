{
  "schema_version": "1.0.0",
  "metadata_type": "project_meta",
  "source_of_truth": "/workspaces/WorkPlace/PORT_CONVENTION.md",
  "project": {
    "number": "03",
    "name": "APICred",
    "root_path": "/workspaces/WorkPlace/APICred"
  },
  "features": {
    "basaltpass_integration": {
      "record_name": "APICred OAuth Client",
      "callback_url": "http://localhost:8103/v1/auth/basalt/callback"
    },
    "authz": {
      "provider": "basaltpass",
      "mode": "app_rbac",
      "basalt_target": {
        "app_id": null,
        "tenant_id_env": "BASALT_TENANT_ID"
      },
      "permissions": [
        {
          "code": "read",
          "name": "Read",
          "description": "Read APICred resources",
          "category": "general"
        },
        {
          "code": "write",
          "name": "Write",
          "description": "Create or update APICred resources",
          "category": "general"
        },
        {
          "code": "admin",
          "name": "Admin",
          "description": "Manage APICred admin capabilities",
          "category": "administration"
        }
      ],
      "roles": [
        {
          "code": "viewer",
          "name": "Viewer",
          "description": "Read-only access"
        },
        {
          "code": "editor",
          "name": "Editor",
          "description": "Can modify non-admin resources"
        },
        {
          "code": "admin",
          "name": "Admin",
          "description": "Full admin access"
        }
      ],
      "role_permissions": {
        "viewer": [
          "read"
        ],
        "editor": [
          "read",
          "write"
        ],
        "admin": [
          "read",
          "write",
          "admin"
        ]
      }
    }
  },
  "service_ports": [
    {
      "service": "backend_api",
      "port": 8103,
      "protocol": "http"
    },
    {
      "service": "frontend_dev",
      "port": 5106,
      "protocol": "http"
    },
    {
      "service": "postgresql",
      "port": 5403,
      "protocol": "tcp"
    },
    {
      "service": "redis",
      "port": 6303,
      "protocol": "tcp"
    }
  ],
  "health_checks": [
    {
      "service": "backend_api",
      "kind": "liveness",
      "path": "/health",
      "url": "http://localhost:8103/health"
    }
  ]
}
