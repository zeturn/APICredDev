{
  "schema_version": "1.0.0",
  "metadata_type": "project_meta",
  "source_of_truth": "/workspaces/WorkPlace/PORT_CONVENTION.md",
  "project": {
    "number": "03",
    "name": "APICred",
    "root_path": "/workspaces/WorkPlace/APICred"
  },
  "features": {
    "basaltpass_integration": {
      "record_name": "APICred OAuth Client",
      "callback_url": "http://localhost:8103/v1/auth/basalt/callback"
    },
    "authz": {
      "provider": "basaltpass",
      "mode": "app_rbac",
      "basalt_target": {
        "app_id": null,
        "tenant_id_env": "BASALT_TENANT_ID"
      },
      "permissions": [
        {
          "code": "user_console",
          "name": "用户控制台权限",
          "description": "允许访问 APICred 用户控制台",
          "category": "console"
        },
        {
          "code": "admin_console",
          "name": "Admin控制台权限",
          "description": "允许访问 APICred Admin 控制台",
          "category": "console"
        }
      ],
      "roles": [
        {
          "code": "user",
          "name": "User",
          "description": "用户控制台角色"
        },
        {
          "code": "admin",
          "name": "Admin",
          "description": "管理员控制台角色"
        }
      ],
      "role_permissions": {
        "user": [
          "user_console"
        ],
        "admin": [
          "user_console",
          "admin_console"
        ]
      }
    }
  },
  "service_ports": [
    {
      "service": "backend_api",
      "port": 8103,
      "protocol": "http"
    },
    {
      "service": "frontend_dev",
      "port": 5106,
      "protocol": "http"
    },
    {
      "service": "postgresql",
      "port": 5403,
      "protocol": "tcp"
    },
    {
      "service": "redis",
      "port": 6303,
      "protocol": "tcp"
    }
  ],
  "health_checks": [
    {
      "service": "backend_api",
      "kind": "liveness",
      "path": "/health",
      "url": "http://localhost:8103/health"
    }
  ]
}
